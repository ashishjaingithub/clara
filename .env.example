# ─── LLM: Groq (required) ────────────────────────────────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=REPLACE_ME_groq_api_key

# Model override — defaults to llama-3.3-70b-versatile (high quality, free-tier eligible)
# GROQ_MODEL=llama-3.3-70b-versatile

# ─── LangSmith Observability ─────────────────────────────────────────────────
# Required in production (startup exits with code 1 if missing)
# Get a key at https://smith.langchain.com
LANGSMITH_API_KEY=REPLACE_ME_langsmith_api_key

# Must be exactly "true" in production to enable trace emission
LANGSMITH_TRACING=false

# LangSmith project name — auto-set to clara-${NODE_ENV} if not provided
# LANGSMITH_PROJECT=clara-development

# ─── Hunter Integration ───────────────────────────────────────────────────────
# URL of the running Hunter backend — required for personalized demos
HUNTER_API_URL=http://localhost:3001

# Bearer token for Hunter API auth (optional — only if Hunter has auth enabled)
# HUNTER_API_KEY=REPLACE_ME_hunter_api_key

# ─── Operator Auth (required in production) ───────────────────────────────────
# Protects POST /api/demo, GET /api/leads, GET /api/admin/cleanup
# Generate: openssl rand -base64 32
# NEVER use a real key here — this file is committed to git
CLARA_OPERATOR_API_KEY=REPLACE_ME_operator_api_key

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite file path — defaults to ./clara.db
# In Railway production: /data/clara-production.db
# DATABASE_PATH=./clara.db

# ─── Email Notifications (optional — leads still captured if not configured) ──
# Get a free API key at https://resend.com
# GMAIL_USER=           # Gmail address to send notifications from
GMAIL_APP_PASSWORD=   # Gmail App Password (not your login password — generate at myaccount.google.com/apppasswords)
OPERATOR_EMAIL=       # Where to receive lead alerts (defaults to GMAIL_USER if not set)
# Email address to receive lead notifications
# OPERATOR_EMAIL=

# ─── Shared credentials (Google Calendar + HubSpot) ──────────────────────────
# From root .env.shared — see /Users/ashishjain/agenticLearning/.env.shared
HUBSPOT_ACCESS_TOKEN=            # HubSpot private app access token
GOOGLE_SERVICE_ACCOUNT_KEY_PATH= # Path to Google service account JSON key file
GOOGLE_CALENDAR_ID=              # Google Calendar ID for appointment bookings
BUSINESS_TIMEZONE=America/Los_Angeles

# ─── Clara HITL gates (Tier 3 actions) ──────────────────────────────────────
# CLARA_CONFIRM_BOOKING and CLARA_CONFIRM_HUBSPOT_WRITE must be set to exactly
# 'true' (lowercase) in production to enable real Calendar/HubSpot writes.
# They are intentionally NOT listed here — set them only in production env,
# never in .env.example, .env.test, or development defaults.
# See: .claude/rules/hitl-gate-exact-string.md

# ─── Simulation mode (for tests and local dev without real APIs) ──────────────
SIMULATE_APIS=                   # Set to 'true' to use mock data (auto-set in tests)

# ─── Application ─────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development

# Required in production: full deployment URL for CORS and absolute URL construction
# Example: https://clara-app.railway.app
# NEXT_PUBLIC_BASE_URL=REPLACE_ME_deployment_url
